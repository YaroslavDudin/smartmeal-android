# ========================
# Файлы Python
# ========================
__pycache__/
*.py[cod]
*$py.class

# ========================
# Виртуальное окружение
# ========================
venv/
env/
ENV/
.venv/

# ========================
# Специфика Django
# ========================
# Локальная база данных (у каждого разработчика должна быть своя!)
db.sqlite3
db.sqlite3-journal

# Медиа-файлы (картинки, которые будут загружать пользователи или админы)
media/

# Папка для собранной статики (собирается командой collectstatic на сервере)
staticfiles/

# ========================
# Файлы окружения и секреты
# ========================
# Здесь будут лежать пароли от PostgreSQL и секретные ключи Django
.env
.env.local

# ========================
# Настройки редакторов и IDE
# ========================
# Игнорируем твои личные настройки VS Code
.vscode/

# На случай, если кто-то из команды использует PyCharm
.idea/
*.iml

# ========================
# Системные файлы ОС
# ========================
.DS_Store
Thumbs.db